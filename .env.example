# FattureInCloud MCP Server - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or use the interactive setup:
#   python auth_setup.py

# === FATTURE IN CLOUD API CREDENTIALS ===
# Register an OAuth2 app at https://developers.fattureincloud.it
FIC_CLIENT_ID=your-client-id
FIC_CLIENT_SECRET=your-client-secret
FIC_ACCESS_TOKEN=your-access-token

# Company ID (retrieved automatically by auth_setup.py)
FIC_COMPANY_ID=0
FIC_COMPANY_NAME=Your Company Name
